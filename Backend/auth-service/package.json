{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Authentication microservice",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node index.js",
    "start": "nodemon index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "build": "npm run lint && npm test",
    "docker:build": "docker build -t auth-service:${npm_package_version} .",
    "docker:push": "docker push registry.example.com/auth-service:${npm_package_version}"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.11.0",
    "redis": "^4.6.7",
    "sequelize": "^6.32.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.41.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "sequelize-cli": "^6.6.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
